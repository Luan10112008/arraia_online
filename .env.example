# Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# Porta do servidor
PORT=3000

# Configuração Supabase
# Vá em: https://app.supabase.com/projects
# Projeto → Settings → API → URLs e Keys
# Copie a URL do projeto (ex: https://seu-projeto.supabase.co)
SUPABASE_URL=https://srxmsekhloahttryyvej.supabase.co/rest/v1/

# Copie a Anonymous Key (ou Public Key) - é a chave publica com prefixo 'eyJ'
SUPABASE_KEY=srxmsekhloahttryyvej

# Opcional: Service Role Key para operações de admin (mais segura)
# SUPABASE_SERVICE_KEY=sua-chave-service-role-aqui

